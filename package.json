{
  "name": "@hacxy/kick",
  "type": "module",
  "version": "0.4.2",
  "packageManager": "pnpm@10.12.3",
  "description": "A project scaffolding CLI tool",
  "author": {
    "name": "Hacxy",
    "email": "hacxy.js@outlook.com",
    "url": "https://hacxy.cn"
  },
  "license": "MIT",
  "keywords": [
    "cli",
    "scaffold",
    "kick",
    "template"
  ],
  "bin": {
    "kick": "index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown --minify",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:staged": "eslint --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "cz": "czg",
    "release": "bump -t -b -c && git push --follow-tags && npm publish --access public",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "degit": "^3.6.0",
    "undici": "^8.7.0"
  },
  "devDependencies": {
    "@hacxy/bump": "^0.4.0",
    "@hacxy/eslint-config": "^0.4.1",
    "@hacxy/tsconfig": "^0.1.0",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "cac": "^6.7.14",
    "chalk": "^5.4.1",
    "czg": "^1.12.0",
    "eslint": "^9.32.0",
    "inquirer": "^12.9.0",
    "lint-staged": "^16.1.2",
    "ora": "^8.2.0",
    "simple-git-hooks": "^2.13.0",
    "tsdown": "^0.13.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.10"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "commit-msg": "node scripts/commit-msg.mjs"
  },
  "lint-staged": {
    "*": [
      "npm run lint:staged"
    ]
  }
}
